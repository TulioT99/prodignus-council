OPENROUTER_API_KEY=replace_with_your_openrouter_api_key
OPENROUTER_MODEL_CONTRARIAN=replace_with_a_valid_openrouter_model_id
OPENROUTER_MODEL_PRODUCT_STRATEGY=replace_with_a_valid_openrouter_model_id
OPENROUTER_MODEL_UX_ACCESSIBILITY=replace_with_a_valid_openrouter_model_id
OPENROUTER_MODEL_DELIVERY_ENGINEERING=replace_with_a_valid_openrouter_model_id
OPENROUTER_MODEL_HUMAN_IMPACT=replace_with_a_valid_openrouter_model_id
OPENROUTER_MODEL_CHAIRMAN=replace_with_a_valid_openrouter_model_id
# Optional: per-request timeout in milliseconds (default: 90000)
OPENROUTER_REQUEST_TIMEOUT_MS=90000
# Optional: HTTP-Referer header sent to OpenRouter for app identification
OPENROUTER_HTTP_REFERER=http://localhost:3000
